<!doctype html>
<html lang="<%= lang %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body>
    <main class="container">
      <div class="row">
        <h1><%= lang === "fr" ? "Soumission de contenu magasin" : "Store Content Submission" %></h1>
        <div>
          <a href="/submit?lang=en">English</a> | <a href="/submit?lang=fr">Francais</a>
        </div>
      </div>
      <p>
        <%= lang === "fr" ? "Partagez votre histoire et televersez une photo." : "Share your store story and upload one photo." %>
      </p>

      <% if (error) { %>
      <div class="alert error"><%= error %></div>
      <% } %>

      <% if (success) { %>
      <div class="alert success"><%= success %></div>
      <% } %>

      <form method="POST" action="/submit" enctype="multipart/form-data" class="card" id="submission-form">
        <input type="hidden" name="lang" value="<%= lang %>" />
        <% questions.forEach((q) => { %>
        <% const questionLabel = typeof q.label === "string" ? q.label : (q.label[lang] || q.label.en); %>
        <label for="<%= q.id %>"><%= questionLabel %> <%= q.required ? "*" : "" %></label>
        <% if (q.type === "textarea") { %>
        <textarea id="<%= q.id %>" name="<%= q.id %>" <%= q.required ? "required" : "" %>></textarea>
        <% } else if (q.type === "select") { %>
        <select id="<%= q.id %>" name="<%= q.id %>" <%= q.required ? "required" : "" %>>
          <option value=""><%= lang === "fr" ? "Selectionnez une option" : "Select one" %></option>
          <% (q.options || []).forEach((option) => { %>
          <% const optionLabel = typeof option.label === "string" ? option.label : (option.label[lang] || option.label.en); %>
          <option value="<%= option.value %>"><%= optionLabel %></option>
          <% }) %>
        </select>
        <% } else if (q.type === "radio") { %>
        <div class="radio-group">
          <% (q.options || []).forEach((option, idx) => { %>
          <% const optionLabel = typeof option.label === "string" ? option.label : (option.label[lang] || option.label.en); %>
          <label class="radio-option" for="<%= q.id %>_<%= idx %>">
            <input
              id="<%= q.id %>_<%= idx %>"
              name="<%= q.id %>"
              type="radio"
              value="<%= option.value %>"
              <%= q.required ? "required" : "" %>
            />
            <span><%= optionLabel %></span>
          </label>
          <% }) %>
        </div>
        <% } else { %>
        <input id="<%= q.id %>" name="<%= q.id %>" type="text" <%= q.required ? "required" : "" %> />
        <% } %> <% }); %>

        <label for="photo"><%= lang === "fr" ? "Televerser une photo" : "Upload Photo" %></label>
        <input id="photo" name="photo" type="file" accept="image/*" />

        <button type="submit"><%= lang === "fr" ? "Soumettre" : "Submit" %></button>
      </form>
    </main>
    <script>
      (function () {
        const photoQuestionName = "photo_permission";
        const yesValue = "yes_upload";
        const photoInput = document.getElementById("photo");

        function updatePhotoRequirement() {
          const selected = document.querySelector(
            `input[name="${photoQuestionName}"]:checked`
          );
          photoInput.required = selected && selected.value === yesValue;
        }

        document
          .querySelectorAll(`input[name="${photoQuestionName}"]`)
          .forEach((el) => el.addEventListener("change", updatePhotoRequirement));

        updatePhotoRequirement();
      })();
    </script>
  </body>
</html>
